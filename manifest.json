{
  "manifest_version": 3,
  "name": "NGISI-LINKNIL",
  "version": "1.7.9",
  
  "icons": {
  "16": "icon16.png",
  "48": "icon48.png",
  "128": "icon128.png"
},

  "permissions": [
  "storage",
  "downloads",
  "downloads.open",
  "scripting",
  "activeTab",
  "sidePanel",
  "notifications",
  "clipboardWrite"
],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
  {
    "resources": [
      "title-generator.js"
    ],
    "matches": ["<all_urls>"]
  }
],
  "background": {
    "service_worker": "background.js"
  },
"action": {
  "default_popup": "popup.html",
  "default_title": "LinkNil",
  "default_icon": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
},
  "side_panel": {
  "default_path": "popup.html"
}
}